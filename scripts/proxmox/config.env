#!/bin/bash
# ==============================================================================
# NTL-SysToolbox — Configuration du Lab Proxmox
# ==============================================================================
#
# CE FICHIER EST LE SEUL A MODIFIER pour adapter le lab a votre Proxmox.
# Remplissez les valeurs ci-dessous AVANT de lancer setup-lab.sh.
#
# Usage :
#   1. Copiez ce fichier : cp config.env config.local.env
#   2. Remplissez config.local.env avec vos valeurs
#   3. Lancez : bash setup-lab.sh (il lira config.local.env s'il existe, sinon config.env)
#
# ==============================================================================

# ------------------------------------------------------------------------------
# PROXMOX — Infos specifiques a votre installation
# ------------------------------------------------------------------------------

# Storage pour les disques des VMs (voir Datacenter > Storage dans la GUI Proxmox)
# Exemples : "local-lvm", "zfs-pool", "ceph-pool", "nfs-share"
# Pour voir vos storages : pvesm status
STORAGE="local-lvm"

# Storage pour les ISOs et cloud images
# Doit etre de type "directory" ou "NFS" (pas LVM)
# Pour voir : pvesm status | grep -E "dir|nfs"
ISO_STORAGE="local"

# Chemin du dossier ISOs sur le Proxmox (generalement /var/lib/vz/template/iso/)
ISO_PATH="/var/lib/vz/template/iso"

# ------------------------------------------------------------------------------
# RESEAU — Configuration du bridge lab
# ------------------------------------------------------------------------------

# Nom du bridge dedie au lab (sera cree automatiquement s'il n'existe pas)
# NE PAS utiliser vmbr0 (c'est le bridge de management Proxmox)
BRIDGE="vmbr10"

# Subnet du lab (les 3 premiers octets)
SUBNET="192.168.10"

# IP du gateway (= IP du Proxmox sur le bridge lab, pour NAT)
GATEWAY="${SUBNET}.1"

# Masque CIDR
CIDR="24"

# Activer NAT pour que les VMs aient Internet ? (yes/no)
# "yes" = les VMs accedent a Internet via le Proxmox (utile pour apt, Windows Update)
# "no"  = lab totalement isole (pas d'Internet dans les VMs)
ENABLE_NAT="yes"

# Interface de sortie du Proxmox (pour le NAT)
# C'est l'interface qui a acces a Internet sur votre Proxmox
# Exemples : "vmbr0", "eno1", "eth0"
# Pour voir : ip route | grep default
NAT_INTERFACE="vmbr0"

# ------------------------------------------------------------------------------
# VMs — IDs et IPs
# ------------------------------------------------------------------------------
# Convention : VM_ID = 10 + dernier octet IP (modifiable si conflit d'IDs)
#
# IMPORTANT : Si un ID est deja pris sur votre Proxmox, changez-le ici.
# Pour voir les IDs utilises : qm list

# DC01 — Windows Server 2022 (Active Directory + DNS)
DC01_VMID="1010"
DC01_IP="${SUBNET}.10"
DC01_NAME="DC01"
DC01_CORES="2"
DC01_RAM="4096"          # en MB
DC01_DISK="40"           # en GB

# WMS-DB — Ubuntu 20.04 (MySQL + SSH)
WMSDB_VMID="1021"
WMSDB_IP="${SUBNET}.21"
WMSDB_NAME="WMS-DB"
WMSDB_CORES="2"
WMSDB_RAM="2048"
WMSDB_DISK="20"

# CLIENT-01 — Windows 10/11 (Poste client, execute le CLI Python)
CLIENT_VMID="1050"
CLIENT_IP="${SUBNET}.50"
CLIENT_NAME="CLIENT-01"
CLIENT_CORES="2"
CLIENT_RAM="4096"
CLIENT_DISK="40"

# SRV-OLD — Windows Server 2012 R2 (machine legacy pour audit EOL)
SRVOLD_VMID="1012"
SRVOLD_IP="${SUBNET}.12"
SRVOLD_NAME="SRV-OLD"
SRVOLD_CORES="1"
SRVOLD_RAM="2048"
SRVOLD_DISK="20"

# SRV-LEGACY — Ubuntu 18.04 (machine legacy pour audit EOL)
SRVLEG_VMID="1018"
SRVLEG_IP="${SUBNET}.18"
SRVLEG_NAME="SRV-LEGACY"
SRVLEG_CORES="1"
SRVLEG_RAM="1024"
SRVLEG_DISK="10"

# ------------------------------------------------------------------------------
# ISOs — Chemins des fichiers ISO (a telecharger manuellement pour Windows)
# ------------------------------------------------------------------------------
# Remplissez les noms de fichiers APRES avoir telecharge les ISOs.
# Le chemin complet sera : ${ISO_PATH}/${ISO_WIN2022}
#
# Ubuntu cloud images : telechargees automatiquement par download-images.sh
# Windows ISOs : telecharger manuellement (Microsoft Evaluation Center)

# Windows Server 2022 Evaluation ISO
# Telecharger : https://www.microsoft.com/en-us/evalcenter/evaluate-windows-server-2022
ISO_WIN2022=""

# Windows 10/11 ISO
# Telecharger : https://www.microsoft.com/en-us/software-download/windows10ISO
ISO_WIN10=""

# Windows Server 2012 R2 Evaluation ISO
# Telecharger : https://www.microsoft.com/en-us/evalcenter/evaluate-windows-server-2012-r2
ISO_WIN2012=""

# VirtIO Drivers ISO (OBLIGATOIRE pour Windows sur Proxmox)
# Telecharge automatiquement par download-images.sh
ISO_VIRTIO="virtio-win.iso"

# Ubuntu cloud images (telechargees par download-images.sh, ne pas modifier)
CLOUD_IMG_2004="focal-server-cloudimg-amd64.img"
CLOUD_IMG_1804="bionic-server-cloudimg-amd64.img"

# ------------------------------------------------------------------------------
# CREDENTIALS — Comptes crees dans les VMs
# ------------------------------------------------------------------------------
# Ces valeurs sont utilisees par les scripts post-install et cloud-init.
# Elles doivent correspondre a ce que vous mettez dans .env du projet Python.

# WMS-DB : user SSH
SSH_USER="sysadmin"
SSH_PASSWORD="SysAdm2026!"

# WMS-DB : user MySQL pour l'application
MYSQL_USER="wms_user"
MYSQL_PASSWORD="WmsP@ss2026"

# DC01 : mot de passe admin AD (SafeModeAdministratorPassword)
AD_SAFE_MODE_PASSWORD="NTL@dmin2026!"

# DC01 : domaine Active Directory
AD_DOMAIN="ntl.local"
AD_NETBIOS="NTL"

# ------------------------------------------------------------------------------
# OPTIONS — Fonctionnalites optionnelles
# ------------------------------------------------------------------------------

# Prendre automatiquement un snapshot "clean-state" apres la config ? (yes/no)
AUTO_SNAPSHOT="yes"

# Demarrer les VMs automatiquement apres creation ? (yes/no)
AUTO_START="yes"

# Afficher les commandes avant de les executer ? (yes/no) — utile pour debug
VERBOSE="yes"
