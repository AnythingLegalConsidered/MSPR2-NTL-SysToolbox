#!/bin/bash
# ==============================================================================
# NTL-SysToolbox — Configuration du Lab Proxmox
# ==============================================================================
# Ce fichier contient UNIQUEMENT les variables specifiques a votre Proxmox.
# Les VMs sont definies dans vms.csv (1 ligne = 1 VM).
# Les images sont mappees dans images.conf.
#
# Usage :
#   1. cp config.env config.local.env
#   2. Remplir config.local.env avec vos valeurs
#   3. bash setup-lab.sh
# ==============================================================================

# ------------------------------------------------------------------------------
# PROXMOX
# ------------------------------------------------------------------------------

# Storage pour les disques VM (voir: pvesm status)
STORAGE="local-lvm"

# Storage pour les ISOs et cloud images (type dir/NFS)
ISO_STORAGE="local"

# Chemin physique du dossier ISOs
ISO_PATH="/var/lib/vz/template/iso"

# Dossier temporaire pour les fichiers generes (autounattend, cloud-init)
WORK_DIR="/tmp/ntl-lab"

# ------------------------------------------------------------------------------
# RESEAU
# ------------------------------------------------------------------------------

# Bridge dedie au lab (cree automatiquement si absent)
BRIDGE="vmbr10"

# Subnet du lab (3 premiers octets)
SUBNET="192.168.10"

# IP du Proxmox sur le bridge (= gateway des VMs)
GATEWAY="${SUBNET}.1"

# Masque CIDR
CIDR="24"

# NAT pour donner Internet aux VMs ? (yes/no)
ENABLE_NAT="yes"

# Interface de sortie pour le NAT (voir: ip route | grep default)
NAT_INTERFACE="vmbr0"

# ------------------------------------------------------------------------------
# CREDENTIALS
# ------------------------------------------------------------------------------

# User SSH cree sur toutes les VMs Linux (cloud-init)
LINUX_USER="sysadmin"
LINUX_PASSWORD="SysAdm2026!"

# Mot de passe Administrator Windows (autounattend)
WINDOWS_ADMIN_PASSWORD="NTL@dmin2026!"

# Active Directory
AD_DOMAIN="ntl.local"
AD_NETBIOS="NTL"
AD_SAFE_MODE_PASSWORD="NTL@dmin2026!"

# MySQL (WMS-DB)
MYSQL_USER="wms_user"
MYSQL_PASSWORD="WmsP@ss2026"

# ------------------------------------------------------------------------------
# API PROXMOX (mode remote — pour *-api.sh scripts)
# ------------------------------------------------------------------------------
# REQUIS si vous n'avez pas de shell sur le Proxmox host.
# Utilisez les scripts *-api.sh depuis le deployer VM ou votre poste.
#
# Creation du token :
#   1. Proxmox Web UI > Datacenter > Permissions > API Tokens > Add
#   2. User: votre compte (ex: etudiant@pam)
#   3. Token ID: ntl-lab
#   4. DECOCHER "Privilege Separation" pour heriter de vos permissions
#   5. Copier le secret (affiche UNE SEULE FOIS)

# URL du Proxmox (avec port)
PVE_HOST=""
# Ex: PVE_HOST="https://proxmox.lab.loc:8006"

# Nom du node Proxmox (visible en haut a gauche dans le web UI)
PVE_NODE="pve"

# Token API (format: user@realm!token-name)
PVE_TOKEN_ID=""
# Ex: PVE_TOKEN_ID="etudiant@pam!ntl-lab"

# Secret du token
PVE_TOKEN_SECRET=""
# Ex: PVE_TOKEN_SECRET="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# ------------------------------------------------------------------------------
# OPTIONS
# ------------------------------------------------------------------------------

# Snapshot automatique apres config ? (yes/no)
AUTO_SNAPSHOT="yes"

# Demarrer les VMs automatiquement ? (yes/no)
AUTO_START="yes"

# Afficher les commandes executees ? (yes/no)
VERBOSE="yes"
